<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A14">

    <!-- Top bar -->
    <TextView
        android:id="@+id/tvAppName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="NeoTUN"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:letterSpacing="0.05"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="52dp"
        android:layout_marginStart="28dp"/>

    <TextView
        android:id="@+id/tvVersion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DPI Bypass"
        android:textSize="11sp"
        android:textColor="#3A3A5C"
        android:letterSpacing="0.15"
        android:textAllCaps="true"
        app:layout_constraintTop_toBottomOf="@id/tvAppName"
        app:layout_constraintStart_toStartOf="@id/tvAppName"
        android:layout_marginTop="3dp"/>

    <!-- Center: big power button -->
    <FrameLayout
        android:id="@+id/btnToggle"
        android:layout_width="172dp"
        android:layout_height="172dp"
        android:background="@drawable/bg_button_idle"
        android:clickable="true"
        android:focusable="true"
        android:elevation="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="60dp">

        <ImageView
            android:id="@+id/ivShield"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_shield"
            android:alpha="0.4"/>
    </FrameLayout>

    <!-- Status pill -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Нажмите для подключения"
        android:textSize="13sp"
        android:textColor="#44445A"
        android:paddingHorizontal="20dp"
        android:paddingVertical="8dp"
        android:background="@drawable/bg_pill"
        app:layout_constraintTop_toBottomOf="@id/btnToggle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp"/>

    <!-- Bottom info row -->
    <LinearLayout
        android:id="@+id/cardStats"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="40dp"
        android:weightSum="2"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:layout_marginEnd="8dp">
            <TextView
                android:text="РЕЖИМ"
                android:textSize="9sp"
                android:textColor="#2E2E4A"
                android:letterSpacing="0.2"
                android:textAllCaps="true"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <TextView
                android:id="@+id/tvMode"
                android:text="TLS Split + OOB"
                android:textSize="13sp"
                android:textColor="#9090B8"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:layout_marginStart="8dp">
            <TextView
                android:text="ПРОКСИ"
                android:textSize="9sp"
                android:textColor="#2E2E4A"
                android:letterSpacing="0.2"
                android:textAllCaps="true"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <TextView
                android:id="@+id/tvProto"
                android:text="SOCKS5 :1080"
                android:textSize="13sp"
                android:textColor="#9090B8"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"/>
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
