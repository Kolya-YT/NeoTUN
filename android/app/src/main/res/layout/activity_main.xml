<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#07070F">

    <!-- App title top-left -->
    <TextView
        android:id="@+id/tvNeo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Neo"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginStart="24dp"
        android:layout_marginTop="48dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/tvTUN"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TUN"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#4F7FFF"
        app:layout_constraintTop_toTopOf="@id/tvNeo"
        app:layout_constraintStart_toEndOf="@id/tvNeo"/>

    <TextView
        android:id="@+id/tvSub"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DPI Bypass"
        android:textSize="11sp"
        android:textColor="#2A2A4A"
        app:layout_constraintTop_toBottomOf="@id/tvNeo"
        app:layout_constraintStart_toStartOf="@id/tvNeo"
        android:layout_marginTop="2dp"/>

    <!-- Glow behind button -->
    <View
        android:id="@+id/vGlow"
        android:layout_width="260dp"
        android:layout_height="260dp"
        android:background="@drawable/bg_glow"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="80dp"/>

    <!-- Power button -->
    <FrameLayout
        android:id="@+id/btnToggle"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:background="@drawable/bg_button_idle"
        android:clickable="true"
        android:focusable="true"
        android:elevation="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="80dp">

        <ImageView
            android:id="@+id/ivShield"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_shield"
            android:alpha="0.5"/>
    </FrameLayout>

    <!-- Status pill -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Нажмите для подключения"
        android:textSize="13sp"
        android:textColor="#2E2E50"
        android:paddingHorizontal="22dp"
        android:paddingVertical="9dp"
        android:background="@drawable/bg_pill"
        app:layout_constraintTop_toBottomOf="@id/btnToggle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="22dp"/>

    <LinearLayout
        android:id="@+id/cardControls"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_card"
        android:padding="14dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/tvStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Профиль обхода"
            android:textColor="#BFC7FF"
            android:textSize="12sp"/>

        <Spinner
            android:id="@+id/spProfile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_pill"
            android:padding="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="8dp">

            <CheckBox
                android:id="@+id/cbHttpSplit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HTTP Host split"
                android:textColor="#BFC7FF"
                android:buttonTint="#4F7FFF"/>

            <CheckBox
                android:id="@+id/cbTlsSplit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TLS SNI split"
                android:textColor="#BFC7FF"
                android:buttonTint="#4F7FFF"/>

            <CheckBox
                android:id="@+id/cbDisorder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Disorder (перестановка сегментов)"
                android:textColor="#BFC7FF"
                android:buttonTint="#4F7FFF"/>

            <CheckBox
                android:id="@+id/cbOob"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OOB marker"
                android:textColor="#BFC7FF"
                android:buttonTint="#4F7FFF"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Bottom cards -->
    <LinearLayout
        android:id="@+id/cardStats"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="24dp"
        android:weightSum="2"
        app:layout_constraintTop_toBottomOf="@id/cardControls"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:layout_marginEnd="8dp">
            <TextView
                android:text="⚡  РЕЖИМ"
                android:textSize="9sp"
                android:textColor="#252545"
                android:letterSpacing="0.15"
                android:textAllCaps="true"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <TextView
                android:id="@+id/tvMode"
                android:text="TLS Split + OOB"
                android:textSize="12sp"
                android:textColor="#5A5A88"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:layout_marginStart="8dp">
            <TextView
                android:text="🔒  ПРОКСИ"
                android:textSize="9sp"
                android:textColor="#252545"
                android:letterSpacing="0.15"
                android:textAllCaps="true"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <TextView
                android:id="@+id/tvProto"
                android:text="SOCKS5 :1080"
                android:textSize="12sp"
                android:textColor="#5A5A88"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"/>
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
